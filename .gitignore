# =========================================================
# ROOT .gitignore (React + FastAPI + Supabase)
# =========================================================

# =========================
# Node / React
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

dist/
build/
.next/
.out/
.tmp/
temp/
.cache/

# =========================
# Python / FastAPI
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyc.*

venv/
env/
.venv/

# =========================
# Environment Variables
# =========================
.env
.env.*
!.env.example

# =========================
# Supabase
# =========================
.supabase/
supabase/.temp/
supabase/.branches/
.supabase/functions/temp/
.supabase/studio/
supabase/functions/.env
supabase/config.toml

# =========================
# Logs
# =========================
logs/
*.log
*.pid
*.seed
*.pid.lock
*.log.*

# =========================
# Databases / Dumps
# =========================
*.sql
!schema.sql
*.dump
*.db
*.sqlite

# =========================
# Coverage / Testing
# =========================
coverage/
htmlcov/
.pytest_cache/
*.lcov
jest-test-results.json
test-results/
cypress/videos/
cypress/screenshots/

# =========================
# IDE / Editors
# =========================
.vscode/
.idea/
*.swp
*.swo

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db
ehthumbs.db
Icon?
__MACOSX/

# =========================
# Archives
# =========================
*.tgz
*.gz
*.zip

# =========================
# Temp / Misc
# =========================
*.bak
*.old
*.orig
*.rej
*.tmp

# =========================
# Uploads / Media (optional)
# =========================
uploads/
media/

# =========================
# Secrets / Keys
# =========================
*.pem
*.key
*.crt

# =========================================================
# END
# =========================================================